{
  "version": 2,
  "builds": [
    { "src": "api/**/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/market/overview", "dest": "/api/market/overview.py" },
    { "src": "/api/stocks", "dest": "/api/stocks.py" },
    { "src": "/api/stock/(.*)", "dest": "/api/stock/[code].py" },
    { "src": "/api/hot", "dest": "/api/hot.py" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
